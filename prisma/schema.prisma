generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String @id @default(uuid())
  email    String @unique
  password String
  name     String

  role      Role
  managerId String?
  manager   User?   @relation("UserManager", fields: [managerId], references: [id])
  employees User[]  @relation("UserManager")

  receipts Receipt[] @relation("CreatedReceipts")

  approvals Approval[] @relation("UserApprovals")
  companyId String?
  company   Company?   @relation("CompanyUsers", fields: [companyId], references: [id])
  adminOf Company? @relation("CompanyAdmin")
  forgotPasswordId  String?
  forgotPassword  ForgotPassword? @relation(fields: [forgotPasswordId], references: [id])
  createdAt DateTime @default(now())
}

model Receipt {
  id String @id @default(uuid())

  amountOriginal   Decimal
  currencyOriginal String

  amountConverted Decimal
  currencyCompany String

  conversionRate Decimal

  category    String
  description String
  expenseDate DateTime
  receiptUrl  String?

  createdById String
  createdBy   User   @relation("CreatedReceipts", fields: [createdById], references: [id])

  approvals Approval[]
  company   Company?   @relation(fields: [companyId], references: [id])
  companyId String?

  createdAt DateTime @default(now())
}

model Company {
  id String @id @default(uuid())

  name     String
  currency String
  country  String
  adminId  String @unique
  admin    User   @relation("CompanyAdmin", fields: [adminId], references: [id])

  users    User[]    @relation("CompanyUsers")
  receipts Receipt[]
}

model Approval {
  id String @id @default(uuid())

  receiptId String
  receipt   Receipt @relation(fields: [receiptId], references: [id])

  approverId String
  approver   User   @relation("UserApprovals", fields: [approverId], references: [id])

  status ApprovalStatus @default(PENDING)

  order Int // for approval flow (Manager → Finance → Director)

  approvedAt DateTime?
  createdAt  DateTime  @default(now())
}

model ForgotPassword {
  id  String @id
  users User[]
}

enum ApproverType {
  MANAGER
  FINANCE
  DIRECTOR
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum Role {
  ADMIN
  EMPLOYEE
  MANAGER
  FINANCE
  DIRECTOR
}
