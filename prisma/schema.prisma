generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String  @id @default(uuid())
  email    String  @unique
  password String
  name     String

  role      Role
  managerId String? @unique
  manager   User?   @relation("UserManager", fields: [managerId], references: [id])
  employees User[]  @relation("UserManager")

  receipts Receipt[] @relation("CreatedReceipts")

  approvals Approval[] @relation("UserApprovals")
  company Company?

  createdAt DateTime  @default(now())
}

model Receipt {
  id          String     @id @default(uuid())
  amount      BigInt
  createdById String
  createdBy User @relation("CreatedReceipts", fields: [createdById], references: [id])
  approvals   Approval[]
}

model Company {
  id String @id @default(uuid())

  name String
  currency String
  country String
  userId String @unique
  user   User @relation(fields: [userId], references: [id])
}

model Approval {
  id String @id @default(uuid())

  receiptId String
  receipt Receipt @relation(fields: [receiptId], references: [id])

  approverId String
  approver User @relation("UserApprovals", fields: [approverId], references: [id])

  status ApprovalStatus @default(PENDING)

  order Int // for approval flow (Manager → Finance → Director)

  approvedAt DateTime?
  createdAt DateTime @default(now())
}

model OTP {
  id        String   @id @unique @default(uuid())
  email     String   @unique
  otp       String
  createdAt DateTime @default(now())
  expiresAt DateTime
}

enum ApproverType {
  MANAGER
  FINANCE
  DIRECTOR
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum Role {
  ADMIN
  EMPLOYEE
  MANAGER
  FINANCE
  DIRECTOR
}
