generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id      String  @id @default(uuid())
  email   String  @unique
  name    String
  password  String
  verified  Boolean @default(false)
  token     String?
}

model Manager {
  id String @id @default(uuid())
  email String  @unique
  password String
  employees Employee[]
}

model Director {
  id String @id @default(uuid())
  email String @unique
  password String
}

model FinanceTeam {
  id String @id @default(uuid())
  email String @unique
  password String
}

model Receipt {
  id String @id @default(uuid())
  amount  BigInt  
  createdById String
  createdBy Employee  @relation(fields: [createdById], references: [id])
  approvals Approval[]
}

model Approval {
  id String @id @default(uuid())

  receiptId String
  receipt Receipt @relation(fields: [receiptId], references: [id])

  approverId String
  approverType ApproverType

  status ApprovalStatus @default(PENDING)

  approvedAt DateTime?
  createdAt DateTime @default(now())
}

model Employee {
  id  String  @id @default(uuid())
  email String  @unique
  password  String
  managerId String 
  manager Manager @relation(fields: [managerId], references: [id])
  receipts Receipt[]
}



model OTP {
  id        String   @id @unique @default(uuid())
  email     String   @unique
  otp       String
  createdAt DateTime @default(now())
  expiresAt DateTime
}


enum ApproverType {
  MANAGER
  FINANCE
  DIRECTOR
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}
