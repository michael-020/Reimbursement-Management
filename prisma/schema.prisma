generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String @id @default(uuid())
  email    String @unique
  password String
  name     String

  role      Role
  managerId String?
  manager   User?   @relation("UserManager", fields: [managerId], references: [id])
  employees User[]  @relation("UserManager")

  receipts Receipt[] @relation("CreatedReceipts")

  approvals Approval[] @relation("UserApprovals")
  companyId String?
  company   Company?   @relation("CompanyUsers", fields: [companyId], references: [id])
  adminOf Company? @relation("CompanyAdmin")
  forgotPasswords ForgotPassword[]
  specificApproverRules ApprovalRule[] @relation("SpecificApproverRules")
  specificApproverSteps ApprovalStep[] @relation("SpecificApproverSteps")
  
  createdAt DateTime @default(now())
}

model Receipt {
  id String @id @default(uuid())

  amountOriginal   Decimal
  currencyOriginal String

  amountConverted Decimal
  currencyCompany String

  conversionRate Decimal

  category    String
  description String
  expenseDate DateTime
  receiptUrl  String?

  createdById String
  createdBy   User   @relation("CreatedReceipts", fields: [createdById], references: [id])
  status    ApprovalStatus

  approvals Approval[]
  company   Company?   @relation(fields: [companyId], references: [id])
  companyId String?

  createdAt DateTime @default(now())
}

model Company {
  id String @id @default(uuid())

  name     String
  currency String
  country  String
  adminId  String @unique
  admin    User   @relation("CompanyAdmin", fields: [adminId], references: [id])

  users    User[]    @relation("CompanyUsers")
  receipts Receipt[]
  approvalRules ApprovalRule[]
  approvalSequences ApprovalSequence[]
}

model Approval {
  id String @id @default(uuid())

  receiptId String
  receipt   Receipt @relation(fields: [receiptId], references: [id])

  approverId String
  approver   User   @relation("UserApprovals", fields: [approverId], references: [id])

  status ApprovalStatus @default(PENDING)

  order Int // for approval flow (Manager → Finance → Director)

  approvedAt DateTime?
  createdAt  DateTime  @default(now())
}

model ForgotPassword {
  id  String @id @default(uuid())
  userId String
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  tempPassword String
  expiresAt DateTime
  isUsed Boolean @default(false)
  
  createdAt DateTime @default(now())
}

model ApprovalRule {
  id String @id @default(uuid())
  
  name String
  description String?
  
  companyId String
  company Company @relation(fields: [companyId], references: [id])
  
  ruleType ApprovalRuleType
  percentageThreshold Int? // For percentage rules
  specificApproverId String? // For specific approver rules
  specificApprover User? @relation("SpecificApproverRules", fields: [specificApproverId], references: [id])
  
  isActive Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ApprovalSequence {
  id String @id @default(uuid())
  
  name String
  description String?
  
  companyId String
  company Company @relation(fields: [companyId], references: [id])
  
  isActive Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  steps ApprovalStep[]
}

model ApprovalStep {
  id String @id @default(uuid())
  
  sequenceId String
  sequence ApprovalSequence @relation(fields: [sequenceId], references: [id])
  
  approverType ApproverType
  specificApproverId String? // For specific user assignments
  specificApprover User? @relation("SpecificApproverSteps", fields: [specificApproverId], references: [id])
  
  order Int // Order in the sequence (1, 2, 3...)
  isRequired Boolean @default(true) // Whether this step is required or can be skipped
  
  createdAt DateTime @default(now())
}

enum ApprovalRuleType {
  PERCENTAGE
  SPECIFIC_APPROVER
  HYBRID
}

enum ApproverType {
  MANAGER
  FINANCE
  DIRECTOR
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum Role {
  ADMIN
  EMPLOYEE
  MANAGER
  FINANCE
  DIRECTOR
}
